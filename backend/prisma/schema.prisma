// ============================================================================
// LIB LE LIB — PRISMA SCHEMA
// PostgreSQL 14+
//
// Translated from lib-le-lib-schema.sql
// Maps to Build Documentation Sections 4, 5.1, 5.2
//
// NOTE: Triggers, functions, and CHECK constraints are handled via a
// separate raw SQL migration (see prisma/migrations/*_add_triggers_and_functions/)
// ============================================================================

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  schemas  = ["public", "verification"]
}

// ============================================================================
// ENUM TYPES
// ============================================================================

enum UserStatus {
  pending_verification
  active
  suspended
  banned
  deleted

  @@map("user_status")
  @@schema("public")
}

enum UserRole {
  member
  verification_officer
  moderator
  admin
  health_professional

  @@map("user_role")
  @@schema("public")
}

enum GenderType {
  man
  woman
  other

  @@map("gender_type")
  @@schema("public")
}

enum RelationshipGoal {
  marriage
  serious_relationship
  friendship

  @@map("relationship_goal")
  @@schema("public")
}

enum LanguageCode {
  am
  en

  @@map("language_code")
  @@schema("public")
}

enum VerificationStatus {
  submitted
  in_review
  approved
  rejected
  expired

  @@map("verification_status")
  @@schema("public")
}

enum VerificationMethod {
  self_upload
  telehealth

  @@map("verification_method")
  @@schema("public")
}

enum LivenessResult {
  pass
  fail
  manual_review

  @@map("liveness_result")
  @@schema("public")
}

enum SwipeAction {
  like
  pass

  @@map("swipe_action")
  @@schema("public")
}

enum MatchStatus {
  active
  unmatched

  @@map("match_status")
  @@schema("public")
}

enum QuizQuestionType {
  single_choice
  multi_choice
  scale
  free_text

  @@map("quiz_question_type")
  @@schema("public")
}

enum MessageType {
  text
  image

  @@map("message_type")
  @@schema("public")
}

enum VideoCallStatus {
  scheduled
  completed
  canceled

  @@map("video_call_status")
  @@schema("public")
}

enum ReportCategory {
  harassment
  fake_profile
  outing_threat
  solicitation
  scam
  underage_suspicion
  other

  @@map("report_category")
  @@schema("public")
}

enum ReportStatus {
  open
  investigating
  resolved
  dismissed

  @@map("report_status")
  @@schema("public")
}

enum ReportSeverity {
  low
  medium
  high
  critical

  @@map("report_severity")
  @@schema("public")
}

enum ModerationActionType {
  warn
  suspend
  ban
  request_resubmission
  none

  @@map("moderation_action_type")
  @@schema("public")
}

enum ResourceCategory {
  treatment_info
  u_equals_u
  hotline
  general

  @@map("resource_category")
  @@schema("public")
}

enum QaThreadStatus {
  open
  answered
  closed

  @@map("qa_thread_status")
  @@schema("public")
}

enum SubscriptionPlan {
  free
  premium

  @@map("subscription_plan")
  @@schema("public")
}

enum SubscriptionStatusEnum {
  active
  canceled
  expired
  past_due

  @@map("subscription_status")
  @@schema("public")
}

// ============================================================================
// CORE IDENTITY  (users, auth, devices)
// ============================================================================

/// Core auth identity. No legal name field by design (doc 4.2).
model User {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  phone         String?   @unique
  email         String?   @unique
  passwordHash  String?   @map("password_hash")
  role          UserRole  @default(member)
  status        UserStatus @default(pending_verification)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  lastLoginAt   DateTime? @map("last_login_at") @db.Timestamptz

  // Relations
  profile               Profile?
  otpCodes              OtpCode[]
  devices               Device[]
  swipesAsActor         Swipe[]              @relation("SwipeActor")
  swipesAsTarget        Swipe[]              @relation("SwipeTarget")
  matchesAsUserA        Match[]              @relation("MatchUserA")
  matchesAsUserB        Match[]              @relation("MatchUserB")
  unmatchedMatches      Match[]              @relation("MatchUnmatchedBy")
  sentMessages          Message[]
  photoRevealGrants     PhotoRevealGrant[]
  blocksAsBLocker       Block[]              @relation("Blocker")
  blocksAsBlocked       Block[]              @relation("Blocked")
  reportsAsReporter     Report[]             @relation("Reporter")
  reportsAsReported     Report[]             @relation("Reported")
  reportsAssigned       Report[]             @relation("ReportAssignedTo")
  moderationActionsAsTarget ModerationAction[] @relation("ModerationTarget")
  moderationActionsAsActor  ModerationAction[] @relation("ModerationActor")
  auditLogs             AuditLog[]
  subscriptions         Subscription[]
  qaThreadsAsMember     QaThread[]           @relation("QaThreadMember")
  qaThreadsAsProfessional QaThread[]         @relation("QaThreadProfessional")
  qaSentMessages        QaMessage[]
  videoCallsInitiated   VideoVerificationCall[]
  successStoriesSubmitted SuccessStory[]     @relation("SuccessStorySubmitter")
  successStoriesApproved  SuccessStory[]     @relation("SuccessStoryApprover")
  resourcesCreated      Resource[]
  verificationRecords   VerificationRecord[] @relation("VerificationUser")
  verificationReviews   VerificationRecord[] @relation("VerificationReviewer")
  livenessReviews       LivenessCheck[]

  @@map("users")
  @@schema("public")
}

model OtpCode {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  destination String
  codeHash    String    @map("code_hash")
  userId      String?   @map("user_id") @db.Uuid
  attempts    Int       @default(0) @db.SmallInt
  expiresAt   DateTime  @map("expires_at") @db.Timestamptz
  consumedAt  DateTime? @map("consumed_at") @db.Timestamptz
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([destination], map: "idx_otp_codes_destination")
  @@map("otp_codes")
  @@schema("public")
}

model Device {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  pushToken  String?  @map("push_token")
  platform   String
  publicKey  String?  @map("public_key")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  lastSeenAt DateTime @default(now()) @map("last_seen_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_devices_user_id")
  @@map("devices")
  @@schema("public")
}

// ============================================================================
// PROFILE  (doc 4.2, 4.3, 4.7)
// ============================================================================

model Region {
  id          String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  countryCode String @map("country_code")
  name        String

  profiles Profile[]

  @@map("regions")
  @@schema("public")
}

/// City/region only — exact GPS coordinates are never stored (doc 5.2).
model Profile {
  userId            String             @id @map("user_id") @db.Uuid
  nickname          String
  dateOfBirth       DateTime           @map("date_of_birth") @db.Date
  gender            GenderType
  regionId          String?            @map("region_id") @db.Uuid
  relationshipGoals RelationshipGoal[] @map("relationship_goals")
  bio               String?
  discreetMode      Boolean            @default(false) @map("discreet_mode")
  lowBandwidthMode  Boolean            @default(false) @map("low_bandwidth_mode")
  preferredLanguage LanguageCode       @default(en) @map("preferred_language")
  createdAt         DateTime           @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime           @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  user              User                        @relation(fields: [userId], references: [id], onDelete: Cascade)
  region            Region?                     @relation(fields: [regionId], references: [id])
  photos            Photo[]
  interestTags      ProfileInterestTag[]
  quizResponses     CompatibilityQuizResponse[]

  @@index([regionId], map: "idx_profiles_region_id")
  @@map("profiles")
  @@schema("public")
}

model InterestTag {
  id   String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name String @unique

  profileInterestTags ProfileInterestTag[]

  @@map("interest_tags")
  @@schema("public")
}

model ProfileInterestTag {
  profileId String @map("profile_id") @db.Uuid
  tagId     String @map("tag_id") @db.Uuid

  profile Profile     @relation(fields: [profileId], references: [userId], onDelete: Cascade)
  tag     InterestTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([profileId, tagId])
  @@map("profile_interest_tags")
  @@schema("public")
}

// ============================================================================
// PHOTOS & VISIBILITY  (doc 4.2: "blurred by default", "revocable reveal")
// ============================================================================

model Photo {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  profileId      String   @map("profile_id") @db.Uuid
  storageRef     String   @map("storage_ref")
  position       Int      @default(0) @db.SmallInt
  isPrimary      Boolean  @default(false) @map("is_primary")
  blurredDefault Boolean  @default(true) @map("blurred_default")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  profile     Profile            @relation(fields: [profileId], references: [userId], onDelete: Cascade)
  revealGrants PhotoRevealGrant[]

  @@index([profileId], map: "idx_photos_profile_id")
  @@map("photos")
  @@schema("public")
}

/// Reveal grant: unblurs a photo for a specific viewer within a specific match.
/// Deleting/expiring this row re-blurs it — the "revocable reveal" mechanic (doc 4.2, 4.4).
model PhotoRevealGrant {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  photoId         String    @map("photo_id") @db.Uuid
  grantedToUserId String    @map("granted_to_user_id") @db.Uuid
  matchId         String?   @map("match_id") @db.Uuid
  grantedAt       DateTime  @default(now()) @map("granted_at") @db.Timestamptz
  revokedAt       DateTime? @map("revoked_at") @db.Timestamptz

  photo       Photo @relation(fields: [photoId], references: [id], onDelete: Cascade)
  grantedTo   User  @relation(fields: [grantedToUserId], references: [id], onDelete: Cascade)
  match       Match? @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([photoId, grantedToUserId])
  @@map("photo_reveal_grants")
  @@schema("public")
}

// ============================================================================
// DISCOVERY & MATCHING  (doc 4.3)
// ============================================================================

model Swipe {
  id        String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actorId   String      @map("actor_id") @db.Uuid
  targetId  String      @map("target_id") @db.Uuid
  action    SwipeAction
  createdAt DateTime    @default(now()) @map("created_at") @db.Timestamptz

  actor  User @relation("SwipeActor", fields: [actorId], references: [id], onDelete: Cascade)
  target User @relation("SwipeTarget", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([actorId, targetId])
  @@index([targetId], map: "idx_swipes_target_id")
  @@map("swipes")
  @@schema("public")
}

model Match {
  id           String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userAId      String      @map("user_a_id") @db.Uuid
  userBId      String      @map("user_b_id") @db.Uuid
  status       MatchStatus @default(active)
  matchedAt    DateTime    @default(now()) @map("matched_at") @db.Timestamptz
  unmatchedAt  DateTime?   @map("unmatched_at") @db.Timestamptz
  unmatchedBy  String?     @map("unmatched_by") @db.Uuid

  userA              User                    @relation("MatchUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userB              User                    @relation("MatchUserB", fields: [userBId], references: [id], onDelete: Cascade)
  unmatchedByUser    User?                   @relation("MatchUnmatchedBy", fields: [unmatchedBy], references: [id])
  messages           Message[]
  photoRevealGrants  PhotoRevealGrant[]
  videoVerificationCalls VideoVerificationCall[]
  reports            Report[]

  @@unique([userAId, userBId])
  @@index([userAId], map: "idx_matches_user_a_id")
  @@index([userBId], map: "idx_matches_user_b_id")
  @@map("matches")
  @@schema("public")
}

// -- Compatibility quiz (doc 4.3) --

model CompatibilityQuizQuestion {
  id           String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  questionText String           @map("question_text")
  questionType QuizQuestionType @map("question_type")
  orderIndex   Int              @default(0) @map("order_index") @db.SmallInt
  active       Boolean          @default(true)

  options   CompatibilityQuizOption[]
  responses CompatibilityQuizResponse[]

  @@map("compatibility_quiz_questions")
  @@schema("public")
}

model CompatibilityQuizOption {
  id         String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  questionId String @map("question_id") @db.Uuid
  optionText String @map("option_text")
  orderIndex Int    @default(0) @map("order_index") @db.SmallInt

  question        CompatibilityQuizQuestion        @relation(fields: [questionId], references: [id], onDelete: Cascade)
  responseOptions CompatibilityQuizResponseOption[]

  @@map("compatibility_quiz_options")
  @@schema("public")
}

model CompatibilityQuizResponse {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  profileId       String   @map("profile_id") @db.Uuid
  questionId      String   @map("question_id") @db.Uuid
  responseText    String?  @map("response_text")
  responseNumeric Decimal? @map("response_numeric")
  answeredAt      DateTime @default(now()) @map("answered_at") @db.Timestamptz

  profile         Profile                          @relation(fields: [profileId], references: [userId], onDelete: Cascade)
  question        CompatibilityQuizQuestion        @relation(fields: [questionId], references: [id], onDelete: Cascade)
  selectedOptions CompatibilityQuizResponseOption[]

  @@unique([profileId, questionId])
  @@map("compatibility_quiz_responses")
  @@schema("public")
}

model CompatibilityQuizResponseOption {
  responseId String @map("response_id") @db.Uuid
  optionId   String @map("option_id") @db.Uuid

  response CompatibilityQuizResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)
  option   CompatibilityQuizOption   @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@id([responseId, optionId])
  @@map("compatibility_quiz_response_options")
  @@schema("public")
}

// ============================================================================
// MESSAGING  (doc 4.4 — end-to-end encrypted; server stores ciphertext only)
// ============================================================================

model Message {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  matchId     String      @map("match_id") @db.Uuid
  senderId    String      @map("sender_id") @db.Uuid
  messageType MessageType @default(text) @map("message_type")
  ciphertext  Bytes       // the server never sees plaintext
  nonce       Bytes
  sentAt      DateTime    @default(now()) @map("sent_at") @db.Timestamptz
  deliveredAt DateTime?   @map("delivered_at") @db.Timestamptz
  readAt      DateTime?   @map("read_at") @db.Timestamptz
  revokedAt   DateTime?   @map("revoked_at") @db.Timestamptz

  match       Match              @relation(fields: [matchId], references: [id], onDelete: Cascade)
  sender      User               @relation(fields: [senderId], references: [id])
  attachments MessageAttachment[]

  @@index([matchId, sentAt], map: "idx_messages_match_id_sent_at")
  @@map("messages")
  @@schema("public")
}

model MessageAttachment {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  messageId      String    @map("message_id") @db.Uuid
  storageRef     String    @map("storage_ref")
  blurredDefault Boolean   @default(true) @map("blurred_default")
  revealedAt     DateTime? @map("revealed_at") @db.Timestamptz
  revokedAt      DateTime? @map("revoked_at") @db.Timestamptz

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@map("message_attachments")
  @@schema("public")
}

model VideoVerificationCall {
  id          String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  matchId     String          @map("match_id") @db.Uuid
  initiatedBy String          @map("initiated_by") @db.Uuid
  status      VideoCallStatus @default(scheduled)
  scheduledAt DateTime?       @map("scheduled_at") @db.Timestamptz
  completedAt DateTime?       @map("completed_at") @db.Timestamptz

  match     Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  initiator User  @relation(fields: [initiatedBy], references: [id])

  @@map("video_verification_calls")
  @@schema("public")
}

// ============================================================================
// SAFETY & TRUST  (doc 4.5, 4.8)
// ============================================================================

/// Mutual disappearance is enforced at the application/query layer.
model Block {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  blockerId String   @map("blocker_id") @db.Uuid
  blockedId String   @map("blocked_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  blocker User @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@map("blocks")
  @@schema("public")
}

model Report {
  id          String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reporterId  String         @map("reporter_id") @db.Uuid
  reportedId  String         @map("reported_id") @db.Uuid
  matchId     String?        @map("match_id") @db.Uuid
  category    ReportCategory
  description String?
  evidenceRef String?        @map("evidence_ref")
  status      ReportStatus   @default(open)
  severity    ReportSeverity @default(low)
  assignedTo  String?        @map("assigned_to") @db.Uuid
  createdAt   DateTime       @default(now()) @map("created_at") @db.Timestamptz
  resolvedAt  DateTime?      @map("resolved_at") @db.Timestamptz

  reporter          User               @relation("Reporter", fields: [reporterId], references: [id])
  reported          User               @relation("Reported", fields: [reportedId], references: [id])
  match             Match?             @relation(fields: [matchId], references: [id])
  assignedToUser    User?              @relation("ReportAssignedTo", fields: [assignedTo], references: [id])
  moderationActions ModerationAction[]

  @@index([status, severity], map: "idx_reports_status_severity")
  @@map("reports")
  @@schema("public")
}

model ModerationAction {
  id           String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reportId     String?              @map("report_id") @db.Uuid
  targetUserId String               @map("target_user_id") @db.Uuid
  actorId      String               @map("actor_id") @db.Uuid
  action       ModerationActionType
  reason       String?
  createdAt    DateTime             @default(now()) @map("created_at") @db.Timestamptz
  expiresAt    DateTime?            @map("expires_at") @db.Timestamptz

  report     Report? @relation(fields: [reportId], references: [id])
  targetUser User    @relation("ModerationTarget", fields: [targetUserId], references: [id])
  actor      User    @relation("ModerationActor", fields: [actorId], references: [id])

  @@map("moderation_actions")
  @@schema("public")
}

/// Append-only by convention. Every verification and moderation decision must write a row here (doc 4.8).
model AuditLog {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actorId    String?   @map("actor_id") @db.Uuid
  actorRole  UserRole? @map("actor_role")
  action     String
  targetType String    @map("target_type")
  targetId   String?   @map("target_id") @db.Uuid
  metadata   Json      @default("{}") @db.JsonB
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz

  actor User? @relation(fields: [actorId], references: [id])

  @@index([targetType, targetId], map: "idx_audit_logs_target")
  @@index([createdAt], map: "idx_audit_logs_created_at")
  @@map("audit_logs")
  @@schema("public")
}

// ============================================================================
// SUPPORT & WELLBEING  (doc 4.6)
// ============================================================================

/// Admin-curated static content only — never user-generated (doc 4.6).
model Resource {
  id        String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title     String
  body      String
  category  ResourceCategory
  language  LanguageCode     @default(en)
  published Boolean          @default(false)
  createdBy String?          @map("created_by") @db.Uuid
  createdAt DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime         @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  creator User? @relation(fields: [createdBy], references: [id])

  @@map("resources")
  @@schema("public")
}

model QaThread {
  id                    String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  memberId              String         @map("member_id") @db.Uuid
  healthProfessionalId  String?        @map("health_professional_id") @db.Uuid
  status                QaThreadStatus @default(open)
  createdAt             DateTime       @default(now()) @map("created_at") @db.Timestamptz
  closedAt              DateTime?      @map("closed_at") @db.Timestamptz

  member             User        @relation("QaThreadMember", fields: [memberId], references: [id])
  healthProfessional User?       @relation("QaThreadProfessional", fields: [healthProfessionalId], references: [id])
  messages           QaMessage[]

  @@map("qa_threads")
  @@schema("public")
}

model QaMessage {
  id       String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  threadId String   @map("thread_id") @db.Uuid
  senderId String   @map("sender_id") @db.Uuid
  content  String
  sentAt   DateTime @default(now()) @map("sent_at") @db.Timestamptz

  thread QaThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender User     @relation(fields: [senderId], references: [id])

  @@index([threadId], map: "idx_qa_messages_thread_id")
  @@map("qa_messages")
  @@schema("public")
}

model SuccessStory {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  submittedByUserId String?   @map("submitted_by_user_id") @db.Uuid
  title             String
  storyText         String    @map("story_text")
  approvedBy        String?   @map("approved_by") @db.Uuid
  published         Boolean   @default(false)
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz
  publishedAt       DateTime? @map("published_at") @db.Timestamptz

  submitter User? @relation("SuccessStorySubmitter", fields: [submittedByUserId], references: [id])
  approver  User? @relation("SuccessStoryApprover", fields: [approvedBy], references: [id])

  @@map("success_stories")
  @@schema("public")
}

// ============================================================================
// MONETIZATION  (doc 10)
// ============================================================================

model Subscription {
  id                     String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                 String                 @map("user_id") @db.Uuid
  plan                   SubscriptionPlan       @default(free)
  status                 SubscriptionStatusEnum @default(active)
  paymentProvider        String?                @map("payment_provider")
  externalSubscriptionId String?                @map("external_subscription_id")
  startedAt              DateTime               @default(now()) @map("started_at") @db.Timestamptz
  currentPeriodEnd       DateTime?              @map("current_period_end") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_subscriptions_user_id")
  @@map("subscriptions")
  @@schema("public")
}

// ============================================================================
// VERIFICATION  (isolated schema — doc 4.1, 5.2, Step 7)
// ============================================================================

model TelehealthPartner {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  countryCode String  @map("country_code")
  contactInfo String? @map("contact_info")
  active      Boolean @default(true)

  referrals TelehealthReferral[]

  @@map("telehealth_partners")
  @@schema("verification")
}

/// Status lifecycle: submitted -> in_review -> approved/rejected -> expired -> re-submission (doc 4.1).
model VerificationRecord {
  id              String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String             @map("user_id") @db.Uuid
  method          VerificationMethod @default(self_upload)
  status          VerificationStatus @default(submitted)
  submittedAt     DateTime           @default(now()) @map("submitted_at") @db.Timestamptz
  decisionAt      DateTime?          @map("decision_at") @db.Timestamptz
  reviewerId      String?            @map("reviewer_id") @db.Uuid
  rejectionReason String?            @map("rejection_reason")
  expiryDate      DateTime?          @map("expiry_date") @db.Date
  createdAt       DateTime           @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime           @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  user      User                  @relation("VerificationUser", fields: [userId], references: [id], onDelete: Cascade)
  reviewer  User?                 @relation("VerificationReviewer", fields: [reviewerId], references: [id])
  documents VerificationDocument[]
  livenessChecks LivenessCheck[]
  referrals TelehealthReferral[]

  @@index([userId], map: "idx_verification_records_user_id")
  @@index([status], map: "idx_verification_records_status")
  @@map("verification_records")
  @@schema("verification")
}

/// Only the verification_officer role may read these via short-lived signed URLs.
/// Purged ~30 days after decision_at.
model VerificationDocument {
  id                   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  verificationRecordId String    @map("verification_record_id") @db.Uuid
  documentType         String    @map("document_type")
  storageRef           String?   @map("storage_ref")
  uploadedAt           DateTime  @default(now()) @map("uploaded_at") @db.Timestamptz
  deletedAt            DateTime? @map("deleted_at") @db.Timestamptz

  verificationRecord VerificationRecord @relation(fields: [verificationRecordId], references: [id], onDelete: Cascade)

  @@map("documents")
  @@schema("verification")
}

model LivenessCheck {
  id                   String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  verificationRecordId String         @map("verification_record_id") @db.Uuid
  selfieStorageRef     String?        @map("selfie_storage_ref")
  result               LivenessResult @default(manual_review)
  reviewedBy           String?        @map("reviewed_by") @db.Uuid
  createdAt            DateTime       @default(now()) @map("created_at") @db.Timestamptz

  verificationRecord VerificationRecord @relation(fields: [verificationRecordId], references: [id], onDelete: Cascade)
  reviewer           User?              @relation(fields: [reviewedBy], references: [id])

  @@map("liveness_checks")
  @@schema("verification")
}

model TelehealthReferral {
  id                   String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  verificationRecordId String @map("verification_record_id") @db.Uuid
  telehealthPartnerId  String @map("telehealth_partner_id") @db.Uuid
  referenceCode        String? @map("reference_code")
  status               String @default("pending")

  verificationRecord VerificationRecord @relation(fields: [verificationRecordId], references: [id], onDelete: Cascade)
  telehealthPartner  TelehealthPartner  @relation(fields: [telehealthPartnerId], references: [id])

  @@map("telehealth_referrals")
  @@schema("verification")
}
